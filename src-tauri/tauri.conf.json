{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageView",
  "version": "0.1.0",
  "identifier": "dev.usageview.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows",
        "title": "UsageView",
        "width": 392,
        "height": 500,
        "resizable": false,
        "zoomHotkeysEnabled": false,
        "center": false,
        "x": 1200,
        "y": 20,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "settings",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows",
        "title": "UsageView - Settings",
        "width": 460,
        "height": 720,
        "minWidth": 430,
        "minHeight": 520,
        "resizable": false,
        "zoomHotkeysEnabled": false,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/sensors/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
